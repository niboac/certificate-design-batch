{
  "name": "certificate-design-batch",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "prod": "vue-tsc --noEmit && vite build && copyfiles -u 1 dist/**/* dist/index.html docs",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "file-saver": "^2.0.5",
    "fontkit": "^2.0.4",
    "pdf-lib": "^1.17.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
